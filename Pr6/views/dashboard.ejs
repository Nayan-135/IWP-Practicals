<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — CricketHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0d13;
      --surface: #111520;
      --surface2: #161b28;
      --border: rgba(255,255,255,0.07);
      --accent: #c9a84c;
      --accent2: #e8c96d;
      --text: #e8eaf0;
      --muted: #6b7280;
      --success: #22c55e;
      --danger: #ef4444;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    nav {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 32px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo { display: flex; align-items: center; gap: 10px; }

    .nav-logo .logo-icon {
      width: 34px; height: 34px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }

    .nav-logo span {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: var(--accent);
    }

    .nav-right { display: flex; align-items: center; gap: 16px; }

    .nav-badge {
      background: rgba(201,168,76,0.12);
      border: 1px solid rgba(201,168,76,0.25);
      color: var(--accent);
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
    }

    .avatar {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, #1e2a4a, #2d3a5e);
      border: 2px solid var(--accent);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; font-weight: 600; color: var(--accent);
    }

    .logout-btn {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.25);
      color: #ef4444;
      padding: 5px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s;
    }
    .logout-btn:hover { background: rgba(239,68,68,0.2); }

    .container { max-width: 1200px; margin: 0 auto; padding: 36px 32px; }

    .hero {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 36px 40px;
      margin-bottom: 28px;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.4s ease both;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .hero::after {
      content: '🏏';
      position: absolute;
      right: 40px; top: 50%;
      transform: translateY(-50%);
      font-size: 100px; opacity: 0.06; line-height: 1;
    }

    .hero-label {
      font-size: 11px; font-weight: 600;
      letter-spacing: 1.5px; text-transform: uppercase;
      color: var(--accent); margin-bottom: 8px;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: 34px; font-weight: 700;
      margin-bottom: 8px; color: var(--text);
    }

    .hero p { color: var(--muted); font-size: 15px; }

    .hero-meta { display: flex; gap: 24px; margin-top: 24px; flex-wrap: wrap; }

    .hero-meta-item {
      display: flex; align-items: center;
      gap: 8px; font-size: 14px; color: var(--muted);
    }

    .hero-meta-item .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--success);
      box-shadow: 0 0 6px var(--success);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px; margin-bottom: 28px;
      animation: fadeUp 0.4s 0.1s ease both;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px; padding: 22px 24px;
      transition: border-color 0.2s;
    }
    .stat-card:hover { border-color: rgba(201,168,76,0.3); }

    .stat-icon { font-size: 22px; margin-bottom: 12px; display: block; }

    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 30px; font-weight: 700;
      color: var(--accent); line-height: 1; margin-bottom: 4px;
    }

    .stat-label {
      font-size: 12px; color: var(--muted);
      font-weight: 500; text-transform: uppercase; letter-spacing: 0.6px;
    }

    .stat-change { font-size: 12px; margin-top: 8px; color: var(--success); font-weight: 500; }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
      animation: fadeUp 0.4s 0.2s ease both;
    }

    .section-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden;
    }

    .section-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }

    .section-header h3 { font-size: 15px; font-weight: 600; color: var(--text); }

    .section-header .tag {
      font-size: 11px;
      background: rgba(201,168,76,0.1);
      color: var(--accent);
      border: 1px solid rgba(201,168,76,0.2);
      padding: 3px 10px; border-radius: 20px; font-weight: 500;
    }

    .match-row {
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 16px;
      transition: background 0.15s;
    }
    .match-row:last-child { border-bottom: none; }
    .match-row:hover { background: var(--surface2); }

    .match-vs { flex: 1; }
    .match-teams { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
    .match-detail { font-size: 12px; color: var(--muted); }
    .match-score { text-align: right; }

    .match-score .score {
      font-family: 'Playfair Display', serif;
      font-size: 16px; color: var(--accent); font-weight: 600;
    }

    .match-score .result { font-size: 11px; margin-top: 3px; }
    .result-win  { color: var(--success); }
    .result-loss { color: var(--danger); }
    .result-live {
      color: var(--accent);
      display: flex; align-items: center;
      gap: 4px; justify-content: flex-end;
    }

    .live-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent);
      animation: pulse 1.5s infinite;
    }

    .profile-section { display: flex; flex-direction: column; gap: 16px; }

    .profile-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px; padding: 24px; text-align: center;
    }

    .profile-avatar {
      width: 72px; height: 72px;
      background: linear-gradient(135deg, #1e2a4a, #2d3a5e);
      border: 3px solid var(--accent); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; font-weight: 700; color: var(--accent);
      margin: 0 auto 14px;
    }

    .profile-name {
      font-family: 'Playfair Display', serif;
      font-size: 20px; font-weight: 700; margin-bottom: 4px;
    }

    .profile-email { font-size: 13px; color: var(--muted); margin-bottom: 16px; }

    .profile-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.2);
      color: var(--accent); padding: 5px 14px;
      border-radius: 20px; font-size: 12px; font-weight: 600;
    }

    .profile-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--border);
      border-top: 1px solid var(--border);
      margin: 20px -24px -24px;
    }

    .profile-stat { background: var(--surface); padding: 16px; text-align: center; }
    .profile-stat:first-child { border-radius: 0 0 0 14px; }
    .profile-stat:last-child  { border-radius: 0 0 14px 0; }

    .profile-stat .val {
      font-family: 'Playfair Display', serif;
      font-size: 22px; color: var(--accent); font-weight: 700;
    }

    .profile-stat .lbl {
      font-size: 11px; color: var(--muted);
      margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px;
    }

    .player-row {
      padding: 14px 20px;
      display: flex; align-items: center; gap: 14px;
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }
    .player-row:last-child { border-bottom: none; }
    .player-row:hover { background: var(--surface2); }

    .player-rank { width: 24px; font-size: 13px; color: var(--muted); font-weight: 600; flex-shrink: 0; }
    .player-rank.gold   { color: #f59e0b; }
    .player-rank.silver { color: #9ca3af; }
    .player-rank.bronze { color: #b45309; }

    .player-info { flex: 1; }
    .player-name { font-size: 14px; font-weight: 600; color: var(--text); }
    .player-country { font-size: 12px; color: var(--muted); }

    .player-rating {
      font-family: 'Playfair Display', serif;
      font-size: 16px; color: var(--accent); font-weight: 700;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    @media (max-width: 900px) {
      .stats-grid   { grid-template-columns: repeat(2, 1fr); }
      .content-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
      .container { padding: 20px 16px; }
      .hero { padding: 24px; }
      nav { padding: 0 16px; }
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-logo">
      <div class="logo-icon">🏏</div>
      <span>CricketHub</span>
    </div>
    <div class="nav-right">
      <span class="nav-badge">🟢 Live Matches</span>
      <div class="avatar"><%= initials %></div>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </nav>

  <div class="container">

    <div class="hero">
      <div class="hero-label">Welcome back</div>
      <h1><%= greeting %>, <%= user.name.split(' ')[0] %> 👋</h1>
      <p>Here's what's happening in cricket today — live scores, top performers & more.</p>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <span class="dot"></span>
          <span>3 Live Matches</span>
        </div>
        <div class="hero-meta-item">
          <span>📅 <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
        <div class="hero-meta-item">
          <span>🌍 ICC Test Championship</span>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-icon">🏆</span>
        <div class="stat-value">142</div>
        <div class="stat-label">Matches Tracked</div>
        <div class="stat-change">↑ 4 this week</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">⚡</span>
        <div class="stat-value">3</div>
        <div class="stat-label">Live Now</div>
        <div class="stat-change" style="color: var(--accent);">● In Progress</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🌟</span>
        <div class="stat-value">18</div>
        <div class="stat-label">Favourite Players</div>
        <div class="stat-change">↑ 2 added</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">📊</span>
        <div class="stat-value">94%</div>
        <div class="stat-label">Prediction Accuracy</div>
        <div class="stat-change">↑ Best this month</div>
      </div>
    </div>

    <div class="content-grid">

      <div class="section-card">
        <div class="section-header">
          <h3>Recent &amp; Live Matches</h3>
          <span class="tag">ICC 2026</span>
        </div>

        <div class="match-row">
          <div class="match-vs">
            <div class="match-teams">🇮🇳 India vs Australia 🇦🇺</div>
            <div class="match-detail">Test · Melbourne Cricket Ground</div>
          </div>
          <div class="match-score">
            <div class="score">342/6 — 218</div>
            <div class="result result-live"><span class="live-dot"></span> Live · Day 3</div>
          </div>
        </div>

        <div class="match-row">
          <div class="match-vs">
            <div class="match-teams">🇬🇧 England vs South Africa 🇿🇦</div>
            <div class="match-detail">ODI · Lord's, London</div>
          </div>
          <div class="match-score">
            <div class="score">287/8 — 265</div>
            <div class="result result-win">England won by 22 runs</div>
          </div>
        </div>

        <div class="match-row">
          <div class="match-vs">
            <div class="match-teams">🇵🇰 Pakistan vs New Zealand 🇳🇿</div>
            <div class="match-detail">T20I · National Stadium, Karachi</div>
          </div>
          <div class="match-score">
            <div class="score">189/5 — 176</div>
            <div class="result result-win">Pakistan won by 13 runs</div>
          </div>
        </div>

        <div class="match-row">
          <div class="match-vs">
            <div class="match-teams">🇱🇰 Sri Lanka vs Bangladesh 🇧🇩</div>
            <div class="match-detail">ODI · R. Premadasa Stadium</div>
          </div>
          <div class="match-score">
            <div class="score">203 — 204/7</div>
            <div class="result result-loss">Bangladesh won by 3 wkts</div>
          </div>
        </div>

        <div class="match-row">
          <div class="match-vs">
            <div class="match-teams">🇦🇪 UAE vs Scotland 🏴󠁧󠁢󠁳󠁣󠁴󠁿</div>
            <div class="match-detail">T20 · ICC World Cup Qualifier</div>
          </div>
          <div class="match-score">
            <div class="score">148/9 — 112</div>
            <div class="result result-win">UAE won by 36 runs</div>
          </div>
        </div>

      </div>

      <div class="profile-section">

        <div class="profile-card">
          <div class="profile-avatar"><%= initials %></div>
          <div class="profile-name"><%= user.name %></div>
          <div class="profile-email"><%= user.email %></div>
          <div class="profile-badge">🏅 Cricket Enthusiast · <%= user.gender %></div>
          <div class="profile-stats">
            <div class="profile-stat">
              <div class="val">312</div>
              <div class="lbl">Days Active</div>
            </div>
            <div class="profile-stat">
              <div class="val">87%</div>
              <div class="lbl">Win Picks</div>
            </div>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3>ICC Test Rankings</h3>
            <span class="tag">Batters</span>
          </div>
          <div class="player-row">
            <div class="player-rank gold">1</div>
            <div class="player-info">
              <div class="player-name">Joe Root</div>
              <div class="player-country">🇬🇧 England</div>
            </div>
            <div class="player-rating">921</div>
          </div>
          <div class="player-row">
            <div class="player-rank silver">2</div>
            <div class="player-info">
              <div class="player-name">Virat Kohli</div>
              <div class="player-country">🇮🇳 India</div>
            </div>
            <div class="player-rating">908</div>
          </div>
          <div class="player-row">
            <div class="player-rank bronze">3</div>
            <div class="player-info">
              <div class="player-name">Steve Smith</div>
              <div class="player-country">🇦🇺 Australia</div>
            </div>
            <div class="player-rating">893</div>
          </div>
          <div class="player-row">
            <div class="player-rank">4</div>
            <div class="player-info">
              <div class="player-name">Babar Azam</div>
              <div class="player-country">🇵🇰 Pakistan</div>
            </div>
            <div class="player-rating">876</div>
          </div>
          <div class="player-row">
            <div class="player-rank">5</div>
            <div class="player-info">
              <div class="player-name">Kane Williamson</div>
              <div class="player-country">🇳🇿 New Zealand</div>
            </div>
            <div class="player-rating">861</div>
          </div>
        </div>

      </div>
    </div>
  </div>

</body>
</html>